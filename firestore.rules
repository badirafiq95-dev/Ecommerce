rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isValidCustomerProfile(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.name is string;
    }

    function isValidOrderCreate(orderId) {
      return signedIn()
        && request.resource.data.id == orderId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "Payment review"
        && request.resource.data.items is list
        && request.resource.data.total is number;
    }

    match /customers/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) && isValidCustomerProfile(userId)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrderCreate(orderId);
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read, write: if isAdmin();
    }

    match /adminSettings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
